<resources>
    <style name="Theme.ChefDadakan" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryVariant">@color/primary_dark</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/secondary</item>
        <item name="colorSecondaryVariant">@color/secondary_dark</item>
        <item name="android:windowBackground">@color/background</item>
        <item name="colorSurface">@color/surface</item>

        <!-- Styling global CardView -->
        <item name="materialCardViewStyle">@style/ChefCardStyle</item>

        <!-- Styling global Button -->
        <item name="materialButtonStyle">@style/ChefButtonStyle</item>
    </style>

    <!-- Style Card global -->
    <style name="ChefCardStyle" parent="Widget.MaterialComponents.CardView">
        <item name="cardCornerRadius">12dp</item>
        <item name="cardElevation">3dp</item>
        <item name="cardBackgroundColor">@color/white</item>
        <item name="contentPadding">0dp</item>
    </style>

    <!-- Style Button global -->
    <style name="ChefButtonStyle" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/primary</item>
        <item name="cornerRadius">8dp</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textStyle">bold</item>
    </style>

    <!-- Style untuk DetailActivity yang punya ActionBar -->
    <style name="Theme.ChefDadakan.Detail" parent="Theme.MaterialComponents.DayNight">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryVariant">@color/primary_dark</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="android:windowBackground">@color/background</item>
        <item name="actionBarStyle">@style/ChefActionBar</item>
    </style>

    <!-- Style ActionBar di Detail -->
    <style name="ChefActionBar" parent="Widget.AppCompat.ActionBar">
        <item name="background">@color/primary</item>
        <item name="titleTextStyle">@style/ChefActionBarTitle</item>
    </style>

    <style name="ChefActionBarTitle" parent="TextAppearance.AppCompat.Widget.ActionBar.Title">
        <item name="android:textColor">@color/white</item>
        <item name="android:textStyle">bold</item>
    </style>
</resources>